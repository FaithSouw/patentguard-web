# PatentGuard frontend environment variables
# Copy this file to .env and fill in real values. Do NOT commit .env.

# Supabase project URL (e.g. https://xxxx.supabase.co)
VITE_SUPABASE_URL=

# Supabase anon/public key. Safe to expose to the browser.
# If both VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY are set, the store
# adapter uses Supabase; otherwise it falls back to localStorage.
VITE_SUPABASE_ANON_KEY=

# NOTE: The Anthropic API key is NO LONGER a frontend variable.
# It now lives only on the backend (env var ANTHROPIC_API_KEY) and the app
# calls Anthropic through the backend /claude proxy. Do not put it here.

# Base URL of the backend API (Railway). Falls back to the dev tunnel if unset.
# Set this in Step 5 to the Railway backend URL, e.g. https://api.patentguard.io
VITE_API_BASE=
